{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "functions": {
    "api/scrape.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/scrape", "destination": "/api/scrape" }
  ],
  "headers": [
    {
      "source": "/featured_apps.json",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=3600, stale-while-revalidate=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
